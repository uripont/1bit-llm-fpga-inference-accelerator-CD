@font-face {
  font-family: "Computer Modern Serif";
  src: url("/fonts/CMUSerif-Roman.woff2") format("woff2");
  font-style: normal;
  font-weight: 400;
  font-display: swap;
}

@font-face {
  font-family: "Computer Modern Serif";
  src: url("/fonts/CMUSerif-Bold.woff2") format("woff2");
  font-style: normal;
  font-weight: 700;
  font-display: swap;
}

@font-face {
  font-family: "Computer Modern Serif";
  src: url("/fonts/CMUSerif-Italic.woff2") format("woff2");
  font-style: italic;
  font-weight: 400;
  font-display: swap;
}

:root {
  --paper: #ffffff;
  --ink: #142238;
  --muted: #5d6674;
  --line: #bac2cc;
  --line-dark: #718096;
  --blue: #335c91;
  --blue-soft: #eaf0fb;
  --rust: #a84d32;
  --rust-soft: #faece6;
  --mint: var(--blue);
  --mint-soft: var(--blue-soft);
  --gold: var(--rust);
  --gold-soft: var(--rust-soft);
  --violet: var(--blue);
  --violet-soft: var(--blue-soft);
  --type-display: 3rem;
  --type-title: 1.5rem;
  --type-body: 1.125rem;
}

* {
  box-sizing: border-box;
}

html,
body,
#root {
  width: 100%;
  height: 100%;
  margin: 0;
  background: var(--paper);
}

body {
  color: var(--ink);
  overflow: hidden;
}

.reveal {
  width: 100%;
  height: 100%;
  font-family: "Computer Modern Serif", "Times New Roman", serif;
  color: var(--ink);
  background: var(--paper);
  touch-action: manipulation;
}

.reveal .slides {
  text-align: left;
}

.reveal .slides section {
  padding: 0;
}

.reveal .slides section.project-slide {
  width: 100%;
  height: 100%;
}

.reveal h1,
.reveal h2,
.reveal h3,
.reveal p,
.reveal ul,
.reveal ol,
.reveal table {
  margin: 0;
  color: inherit;
  
  
}

.reveal h1,
.reveal h2,
.reveal h3,
.reveal strong {
  font-family: "Computer Modern Serif", "Times New Roman", serif;
}

.reveal h1 {
  
  line-height: 1.03;
  font-weight: 700;
}

.reveal h2 {
  
  line-height: 1.08;
  font-weight: 700;
}

.reveal h3 {
  
  line-height: 1.15;
  font-weight: 700;
}

.reveal p,
.reveal li,
.reveal td,
.reveal th {
  
  line-height: 1.32;
}

.reveal a {
  color: var(--blue);
  text-decoration: underline;
  text-decoration-thickness: 1px;
  text-underline-offset: 0.15em;
}

.reveal code {
  font-family: "SFMono-Regular", Consolas, monospace;
  color: var(--ink);
  background: #f2f4f7;
  padding: 0.08em 0.28em;
  border-radius: 3px;
}

.slide-shell {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 36px 48px;
  overflow: hidden;
  overscroll-behavior: contain;
  background: var(--paper);
}

.slide-content {
  display: grid;
  grid-template-rows: auto auto;
  width: 100%;
  max-height: 100%;
  min-height: 0;
}

.slide-shell.has-source .slide-content {
  max-height: calc(100% - 64px);
}

.slide-shell::before {
  display: none;
}

.slide-header {
  display: grid;
  grid-template-columns: 1fr;
  align-content: start;
  gap: 6px;
  padding-bottom: 18px;
}

.slide-header h2 {
  max-width: 1160px;
}

.kicker {
  color: var(--rust) !important;
  font-family: "SFMono-Regular", Consolas, monospace;
  
  font-weight: 700;
  
  
}

.slide-header .kicker,
.cover-copy > .kicker {
  display: none;
}

.subtitle {
  max-width: 1080px;
  color: var(--muted) !important;
  
  line-height: 1.35 !important;
}

.slide-body {
  min-height: 0;
}

.slide-source {
  position: absolute;
  right: 62px;
  bottom: 48px;
  left: 62px;
  color: var(--muted);
  
  line-height: 1.25;
}

.slide-source a {
  color: inherit;
}

.grid-2,
.grid-3,
.metric-grid,
.split-visual,
.result-grid {
  display: grid;
  gap: 24px;
}

.grid-2,
.split-visual,
.result-grid {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.grid-3,
.metric-grid {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.align-center {
  align-items: center;
}

.stack {
  display: grid;
  gap: 16px;
}

.stack-tight {
  display: grid;
  gap: 9px;
}

.lead {
  max-width: 1050px;
  
  line-height: 1.28 !important;
}

.lede-small {
  max-width: 1040px;
  color: var(--muted) !important;
  
}

.emphasis {
  color: var(--rust);
}

.muted {
  color: var(--muted) !important;
}

.mono {
  font-family: "SFMono-Regular", Consolas, monospace;
}

.metric {
  min-height: 130px;
  padding: 18px 20px 16px;
  border-top: 4px solid currentColor;
  background: #f8f9fb;
}

.metric strong {
  display: block;
  
  line-height: 1;
  font-variant-numeric: tabular-nums;
}

.metric span {
  display: block;
  margin-top: 7px;
  color: var(--ink);
  
  line-height: 1.18;
}

.metric small {
  display: block;
  margin-top: 8px;
  color: var(--muted);
  
  line-height: 1.25;
}

.tone-ink { color: var(--ink); }
.tone-blue { color: var(--blue); }
.tone-mint { color: var(--mint); }
.tone-rust { color: var(--rust); }
.tone-gold { color: var(--gold); }
.tone-violet { color: var(--violet); }

.panel {
  padding: 20px 22px;
  border: 1px solid var(--line);
  border-radius: 5px;
  background: #fff;
}

.panel-blue,
.panel-mint,
.panel-violet { background: var(--blue-soft); border-color: var(--blue); }
.panel-rust,
.panel-gold { background: var(--rust-soft); border-color: var(--rust); }

.panel-label {
  display: block;
  margin-bottom: 6px;
  color: var(--ink);
  font-family: "Computer Modern Serif", "Times New Roman", serif;
  
  font-weight: 700;
  
  
}

.bullet-list {
  display: grid;
  gap: 12px;
  padding-left: 1.15em !important;
}

.bullet-list li::marker {
  color: var(--rust);
}

.bullet-list.compact {
  gap: 7px;
}

.flow {
  display: flex;
  align-items: stretch;
  gap: 0;
  width: 100%;
}

.flow-item {
  display: flex;
  flex: 1 1 0;
  align-items: center;
  min-width: 0;
}

.flow-box {
  display: grid;
  flex: 1;
  place-content: center;
  min-width: 0;
  min-height: 140px;
  padding: 16px;
  border: 1px solid var(--line-dark);
  border-radius: 5px;
  color: var(--ink);
  text-align: center;
  background: #fff;
}

.flow-box.tone-blue,
.flow-box.tone-mint,
.flow-box.tone-violet { background: var(--blue-soft); border-color: var(--blue); }
.flow-box.tone-rust,
.flow-box.tone-gold { background: var(--rust-soft); border-color: var(--rust); }

.flow-box small {
  margin-bottom: 4px;
  color: var(--muted);
  font-family: "SFMono-Regular", Consolas, monospace;
  
  
}

.flow-box strong {
  
  line-height: 1.13;
}

.flow-box span {
  display: block;
  margin-top: 6px;
  color: var(--muted);
  
  line-height: 1.25;
}

.flow-arrow {
  flex: 0 0 34px;
  color: var(--line-dark);
  
  text-align: center;
}

.flow-compact .flow-box {
  min-height: 102px;
  padding: 12px;
}

.callout {
  padding: 16px 20px;
  border-left: 5px solid currentColor;
  background: #f8f9fb;
}

.callout.tone-mint { background: var(--mint-soft); }
.callout.tone-rust { background: var(--rust-soft); }
.callout.tone-blue { background: var(--blue-soft); }
.callout.tone-gold { background: var(--gold-soft); }

.callout p {
  color: var(--ink);
  
}

.callout p strong {
  color: currentColor;
}

.data-table {
  width: 100%;
  border-collapse: collapse;
  font-variant-numeric: tabular-nums;
}

.data-table th {
  padding: 7px 10px;
  border-bottom: 2px solid var(--ink);
  
  text-align: left;
}

.data-table td {
  padding: 9px 10px;
  border-bottom: 1px solid #dfe3e8;
  
}

.data-table th:not(:first-child),
.data-table td:not(:first-child) {
  text-align: right;
}

.data-table .status-pass {
  color: var(--mint);
  font-weight: 700;
}

.data-table .status-fail {
  color: var(--rust);
  font-weight: 700;
}

.bar-compare {
  display: grid;
  gap: 20px;
}

.bar-row {
  display: grid;
  grid-template-columns: 128px 1fr;
  gap: 16px;
  align-items: start;
}

.bar-row-label {
  padding-top: 25px;
  color: var(--muted);
  font-family: "SFMono-Regular", Consolas, monospace;
  
  font-weight: 700;
  
}

.bar-row-series {
  display: grid;
  gap: 9px;
}

.bar-line {
  display: grid;
  grid-template-columns: 82px 1fr 152px;
  gap: 10px;
  align-items: center;
}

.bar-label {
  color: var(--muted);
  
}

.bar-track {
  height: 22px;
  background: #edf0f3;
}

.bar-fill {
  height: 100%;
  background: currentColor;
}

.bar-line strong {
  
  font-variant-numeric: tabular-nums;
}

.chart-frame {
  position: relative;
  height: 395px;
  padding: 8px 12px 0;
  border: 1px solid var(--line);
  border-radius: 5px;
}

.chart-frame svg {
  width: 100%;
  height: 335px;
}

.grid-line {
  stroke: #dde2e7;
  stroke-width: 1;
}

.axis-label {
  fill: var(--muted);
  font-family: "SFMono-Regular", Consolas, monospace;
  
}

.chart-line {
  fill: none;
  stroke-width: 5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

.chart-q1 { stroke: var(--blue); }
.chart-attention { stroke: var(--rust); }
.point-q1 { fill: var(--blue); }
.point-attention { fill: var(--rust); }

.chart-legend {
  display: flex;
  justify-content: center;
  gap: 28px;
  color: var(--muted);
  
}

.chart-legend i {
  display: inline-block;
  width: 20px;
  height: 4px;
  margin-right: 6px;
  vertical-align: middle;
}

.legend-q1 { background: var(--blue); }
.legend-attention { background: var(--rust); }

.resource-gauge {
  display: grid;
  gap: 7px;
}

.resource-label,
.resource-note {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
}

.resource-label strong,
.resource-label span,
.resource-note strong,
.resource-note span {
  
}

.resource-label span,
.resource-note span {
  color: var(--muted);
}

.resource-track {
  height: 18px;
  background: #edf0f3;
}

.resource-fill {
  height: 100%;
  background: currentColor;
}

.bit-field {
  display: grid;
  grid-template-columns: repeat(16, 1fr);
  gap: 4px;
}

.bit {
  display: grid;
  place-items: center;
  aspect-ratio: 1;
  min-width: 0;
  border: 1px solid #8fa0b3;
  font-family: "SFMono-Regular", Consolas, monospace;
  
  background: #f6f8fa;
}

.bit:nth-child(3n) { background: var(--mint-soft); }
.bit:nth-child(5n) { background: var(--rust-soft); }

.equation {
  padding: 18px 20px;
  border-top: 2px solid var(--ink);
  border-bottom: 1px solid var(--line);
  
  text-align: center;
  font-style: italic;
}

.chip-visual {
  position: relative;
  display: grid;
  place-items: center;
  width: 420px;
  height: 420px;
  margin: 0 auto;
}

.chip-body {
  position: relative;
  display: grid;
  place-items: center;
  width: 270px;
  height: 270px;
  border: 7px solid var(--ink);
  outline: 1px solid var(--line-dark);
  background: var(--gold-soft);
}

.chip-body strong {
  
  text-align: center;
}

.chip-body span {
  display: block;
  margin-top: 8px;
  color: var(--muted);
  font-family: "SFMono-Regular", Consolas, monospace;
  
  text-align: center;
}

.board-image {
  display: block;
  width: 100%;
  max-height: 430px;
  object-fit: contain;
  filter: drop-shadow(0 9px 12px rgb(20 34 56 / 0.12));
}

.architecture-grid {
  display: grid;
  grid-template-columns: 0.85fr 0.85fr 1.25fr 1.2fr;
  gap: 28px;
  align-items: center;
}

.arch-node {
  position: relative;
  display: grid;
  place-content: center;
  min-height: 155px;
  padding: 16px;
  border: 1px solid var(--line-dark);
  border-radius: 5px;
  text-align: center;
}

.arch-node::after {
  content: "→";
  position: absolute;
  right: -26px;
  top: 50%;
  color: var(--line-dark);
  
  transform: translateY(-50%);
}

.arch-node:last-child::after {
  display: none;
}

.architecture-grid > :last-child .arch-node::after {
  display: none;
}

.arch-node strong {
  
}

.arch-node span {
  margin-top: 5px;
  color: var(--muted);
  
}

.arch-stack {
  display: grid;
  gap: 10px;
}

.arch-stack .arch-node {
  min-height: 72px;
}

.memory-front-end {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  padding: 12px;
  border: 1px solid var(--rust);
  border-radius: 5px;
  background: var(--rust-soft);
}

.memory-front-end > strong {
  grid-column: 1 / -1;
  
  text-align: center;
}

.memory-path {
  display: grid;
  place-content: center;
  min-height: 76px;
  padding: 8px;
  border: 1px solid var(--rust);
  border-radius: 4px;
  background: #fff;
  text-align: center;
}

.memory-path strong {  }
.memory-path span { color: var(--muted);  }

.timeline {
  display: grid;
  grid-template-columns: repeat(6, 1fr);
  gap: 0;
  padding-top: 20px;
}

.timeline-step {
  position: relative;
  min-height: 170px;
  padding: 28px 12px 14px;
  border-top: 3px solid var(--line);
}

.timeline-step::before {
  content: "";
  position: absolute;
  top: -8px;
  left: 12px;
  width: 13px;
  height: 13px;
  border: 3px solid var(--paper);
  border-radius: 50%;
  background: var(--blue);
  box-shadow: 0 0 0 1px var(--blue);
}

.timeline-step:nth-child(2)::before,
.timeline-step:nth-child(5)::before { background: var(--rust); box-shadow: 0 0 0 1px var(--rust); }
.timeline-step:nth-child(3)::before,
.timeline-step:nth-child(6)::before { background: var(--mint); box-shadow: 0 0 0 1px var(--mint); }

.timeline-step small {
  font-family: "SFMono-Regular", Consolas, monospace;
  
  color: var(--muted);
}

.timeline-step strong {
  display: block;
  margin-top: 5px;
  
}

.timeline-step p {
  margin-top: 6px;
  color: var(--muted);
  
}

.cover-slide .slide-shell {
  padding: 48px 60px;
  background: var(--paper);
}

.cover-slide .slide-shell::before {
  display: none;
}

.cover-layout {
  display: grid;
  grid-template-columns: 1.2fr 0.8fr;
  gap: 68px;
  align-items: center;
  height: auto;
}

.cover-copy {
  display: grid;
  gap: 20px;
}

.cover-copy .kicker {
  
}

.cover-subtitle {
  max-width: 760px;
  color: var(--muted) !important;
  
}

.cover-meta {
  display: flex;
  gap: 24px;
  padding-top: 10px;
  color: var(--muted);
  font-family: "SFMono-Regular", Consolas, monospace;
  
}

.cover-visual {
  display: grid;
  gap: 16px;
}

.cover-chip {
  display: grid;
  grid-template-columns: 1fr auto 1fr;
  gap: 16px;
  align-items: center;
}

.cover-chip .panel {
  min-height: 96px;
  text-align: center;
}

.cover-chip .arrow {
  color: var(--rust);
  
}

.quote {
  padding-left: 20px;
  border-left: 4px solid var(--rust);
  
  line-height: 1.25 !important;
}

.claim-flag {
  display: inline-block;
  padding: 4px 7px;
  border: 1px solid var(--gold);
  color: var(--gold);
  font-family: "SFMono-Regular", Consolas, monospace;
  
  font-weight: 700;
  
}

.big-result {
  
  line-height: 1 !important;
  font-variant-numeric: tabular-nums;
}

.small-caps {
  font-family: "SFMono-Regular", Consolas, monospace;
  
  
  
}

.caveat {
  padding: 12px 16px;
  border: 1px solid var(--rust);
  background: var(--gold-soft);
  color: var(--ink);
  
}

.reveal .controls,
.reveal .slide-number {
  display: none !important;
}

.reveal .progress {
  height: 3px;
  color: var(--rust);
}

.deck-page-count {
  position: fixed;
  bottom: 14px;
  left: 20px;
  z-index: 50;
  color: var(--muted);
  font-family: "Computer Modern Serif", "Times New Roman", serif;
  font-size: var(--type-body);
  line-height: 1;
  pointer-events: none;
}

.deck-arrows {
  position: fixed;
  right: 12px;
  bottom: 6px;
  z-index: 50;
  display: flex;
  gap: 4px;
}

.deck-arrows button {
  display: grid;
  place-items: center;
  width: 48px;
  height: 48px;
  padding: 0 0 6px;
  border: 0;
  color: var(--ink);
  background: transparent;
  font-family: "Computer Modern Serif", "Times New Roman", serif;
  font-size: 3rem;
  line-height: 1;
  cursor: pointer;
}

.deck-arrows button:disabled {
  opacity: 0.22;
  cursor: default;
}

.deck-arrows button:focus-visible {
  outline: 2px solid var(--blue);
  outline-offset: 1px;
  
}

@media (max-width: 1100px) {
  .slide-shell {
    padding: 34px 40px;
  }

  .slide-header {
    padding-bottom: 18px;
  }

  .grid-2,
  .grid-3,
  .metric-grid,
  .split-visual,
  .result-grid {
    gap: 18px;
  }

  .flow-box {
    min-height: 120px;
    padding: 13px;
  }

  .flow-compact .flow-box {
    min-height: 92px;
  }

  .flow-arrow {
    flex-basis: 24px;
  }

  .architecture-grid {
    gap: 20px;
  }

  .arch-node::after {
    right: -19px;
  }

  .cover-slide .slide-shell {
    padding: 44px 48px;
  }

  .cover-layout {
    gap: 38px;
  }
}

@media (max-width: 900px) {
  .reveal h1 {
    
    line-height: 1.05;
  }

  .reveal h2 {
    
    line-height: 1.1;
  }

  .reveal h3 {
    
  }

  .reveal p,
  .reveal li,
  .reveal td,
  .reveal th {
    
  }

  .slide-shell,
  .cover-slide .slide-shell {
    padding: 29px 24px;
    overflow: hidden;
  }

  .slide-header {
    gap: 4px;
    padding-bottom: 12px;
  }

  .slide-header h2,
  .subtitle,
  .lead,
  .lede-small {
    max-width: none;
  }

  .subtitle {
    
  }

  .slide-source {
    right: 86px;
    bottom: 48px;
    left: 24px;
    
    overflow-wrap: anywhere;
  }

  .grid-2,
  .split-visual,
  .result-grid {
    grid-template-columns: minmax(0, 1fr);
    gap: 10px;
  }

  .grid-3,
  .metric-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 6px;
  }

  .stack {
    gap: 10px;
  }

  .stack-tight {
    gap: 8px;
  }

  .lead {
    
  }

  .lede-small {
    
  }

  .panel {
    padding: 12px 14px;
  }

  .metric {
    min-height: 0;
    padding: 9px 8px;
  }

  .metric strong {
    
  }

  .metric span {
    
  }

  .metric small {
    
  }

  .bullet-list {
    gap: 9px;
  }

  .flow {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 6px;
  }

  .flow-item {
    display: block;
    width: auto;
  }

  .flow-item:nth-child(odd):last-child {
    grid-column: 1 / -1;
  }

  .flow-box,
  .flow-compact .flow-box {
    width: 100%;
    min-height: 0;
    padding: 10px;
  }

  .flow-box strong {
    
  }

  .flow-box span {
    
  }

  .flow-box small {
    
  }

  .flow-arrow {
    display: none;
  }

  .callout {
    padding: 10px 13px;
  }

  .callout p {
    
  }

  .panel-label {
    
  }

  .bar-compare {
    gap: 18px;
  }

  .bar-row {
    grid-template-columns: 1fr;
    gap: 7px;
  }

  .bar-row-label {
    padding-top: 0;
    
  }

  .bar-line {
    grid-template-columns: 70px minmax(60px, 1fr) auto;
    gap: 7px;
  }

  .bar-label,
  .bar-line strong {
    
  }

  .bar-track {
    height: 17px;
  }

  .chart-frame {
    height: auto;
    padding: 8px 8px 10px;
  }

  .chart-frame svg {
    display: block;
    height: auto;
    aspect-ratio: 820 / 360;
  }

  .chart-legend {
    flex-wrap: wrap;
    gap: 8px 18px;
    
  }

  .data-table {
    display: table;
    table-layout: fixed;
    overflow: visible;
    white-space: normal;
  }

  .data-table th,
  .data-table td {
    padding: 5px 4px;
    
    overflow-wrap: anywhere;
  }

  .architecture-grid {
    grid-template-columns: minmax(0, 1fr);
    gap: 18px;
  }

  .arch-node,
  .arch-stack .arch-node {
    min-height: 0;
    padding: 14px;
  }

  .arch-node strong {
    
  }

  .arch-node span {
    
  }

  .arch-node::after {
    content: "↓";
    right: 50%;
    top: auto;
    bottom: -18px;
    transform: translateX(50%);
  }

  .architecture-grid > :last-child .arch-node::after {
    display: none;
  }

  .memory-path strong {
    
  }

  .memory-path span {
    
  }

  .timeline {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 8px;
    padding: 0;
  }

  .timeline-step {
    min-height: 0;
    padding: 10px 14px 12px 22px;
    border-top: 0;
    border-left: 3px solid var(--line);
  }

  .timeline-step::before {
    top: 13px;
    left: -8px;
  }

  .timeline-step small {
    
  }

  .timeline-step strong {
    
  }

  .timeline-step p {
    
  }

  .evidence-slide .grid-3 {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .evidence-slide .grid-3 > :last-child {
    grid-column: 1 / -1;
  }

  .cover-layout {
    grid-template-columns: minmax(0, 1fr);
    gap: 28px;
    align-items: start;
    height: auto;
    min-height: 0;
  }

  .cover-copy {
    gap: 16px;
  }

  .cover-subtitle {
    
  }

  .cover-meta {
    flex-wrap: wrap;
    gap: 8px 16px;
    
  }

  .bit-field {
    grid-template-columns: repeat(8, minmax(0, 1fr));
  }

  .bit {
    
  }

  .board-image {
    max-height: 42vh;
  }

  .chip-visual {
    width: min(175px, 100%) !important;
    height: min(175px, 44vw) !important;
  }

  .chip-body {
    width: min(125px, 32vw) !important;
    height: min(125px, 32vw) !important;
  }

  .big-result {
    
  }

  .equation {
    padding: 14px 12px;
    
    overflow-wrap: anywhere;
  }

  .caveat {
    
  }

  .deck-page-count {
    bottom: 13px;
    left: 12px;
  }

  .deck-arrows {
    right: 6px;
    bottom: 4px;
  }
}

@media (max-width: 420px) {
  .reveal h1 {
    
  }

  .reveal h2 {
    
  }

  .slide-shell,
  .cover-slide .slide-shell {
    padding: 20px 18px 26px;
  }

  .bar-line {
    grid-template-areas:
      "label value"
      "track track";
    grid-template-columns: 1fr auto;
  }

  .bar-label {
    grid-area: label;
  }

  .bar-track {
    grid-area: track;
  }

  .bar-line strong {
    grid-area: value;
    text-align: right;
  }

  .cover-chip {
    gap: 9px;
  }

  .cover-chip .panel {
    min-height: 78px;
    padding: 12px 9px;
  }
}

@media (max-width: 700px) and (min-height: 651px) {
  .motivation-slide .metric-grid {
    grid-template-columns: minmax(0, 1fr);
    gap: 8px;
  }

  .motivation-slide .metric {
    padding: 10px 12px;
  }

  .motivation-slide .metric span {
    margin-top: 4px;
  }
}

@media (max-height: 650px) {
  .slide-shell,
  .cover-slide .slide-shell {
    padding-top: 16px;
    padding-bottom: 16px;
    overflow: hidden;
  }

  .slide-header {
    padding-bottom: 8px;
  }

  .reveal h1 {
    
  }

  .reveal h2 {
    
  }

  .reveal h3 {
    
  }

  .reveal p,
  .reveal li,
  .reveal td,
  .reveal th {
    
  }

  .stack {
    gap: 7px;
  }

  .panel {
    padding: 9px 11px;
  }

  .metric {
    min-height: 0;
    padding: 8px 9px;
  }

  .metric strong {
    
  }

  .metric span {
    margin-top: 4px;
    
  }

  .metric small {
    margin-top: 4px;
    
  }

  .flow-box,
  .flow-compact .flow-box {
    min-height: 0;
    padding: 8px;
  }

  .flow-box strong {
    
  }

  .flow-box span {
    margin-top: 3px;
    
  }

  .callout {
    padding: 8px 11px;
  }

  .callout p {
    
  }

  .bar-compare,
  .bar-row-series {
    gap: 6px;
  }

  .bar-row {
    gap: 6px;
  }

  .bar-track {
    height: 13px;
  }

  .slide-source {
    padding-top: 5px;
    
  }

  .lead {
    
  }

  .lede-small,
  .subtitle {
    
  }

  .chart-frame {
    height: auto;
  }

  .chart-frame svg {
    height: min(185px, 48vh);
  }

  .board-image {
    max-height: 48vh;
  }

  .equation {
    padding: 8px 10px;
    
  }

  .big-result {
    
  }

  .cover-copy {
    gap: 9px;
  }

  .cover-subtitle {
    
  }

  .cover-meta {
    padding-top: 2px;
    
  }
}

@media (max-height: 650px) and (min-aspect-ratio: 4 / 3) {
  .slide-shell,
  .cover-slide .slide-shell {
    padding-right: 24px;
    padding-left: 24px;
  }

  .grid-2,
  .split-visual,
  .result-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .grid-3,
  .metric-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 8px;
  }

  .flow {
    display: flex;
    flex-direction: row;
    gap: 0;
  }

  .flow-item,
  .flow-item:nth-child(odd):last-child {
    display: flex;
    flex: 1 1 0;
    grid-column: auto;
    width: auto;
  }

  .flow-arrow {
    display: block;
    flex: 0 0 18px;
    transform: none;
  }

  .architecture-grid {
    grid-template-columns: 0.85fr 0.85fr 1.25fr 1.2fr;
    gap: 18px;
  }

  .arch-node,
  .arch-stack .arch-node {
    min-height: 58px;
    padding: 8px;
  }

  .arch-node::after {
    content: "→";
    right: -17px;
    top: 50%;
    bottom: auto;
    transform: translateY(-50%);
  }

  .architecture-grid > :last-child .arch-node::after {
    display: none;
  }

  .memory-front-end {
    grid-template-columns: 1fr 1fr;
    padding: 7px;
  }

  .memory-path {
    min-height: 48px;
  }

  .timeline {
    grid-template-columns: repeat(6, minmax(0, 1fr));
    gap: 0;
    padding-top: 12px;
  }

  .timeline-step {
    min-height: 112px;
    padding: 20px 8px 8px;
    border-top: 3px solid var(--line);
    border-left: 0;
  }

  .timeline-step::before {
    top: -8px;
    left: 10px;
  }

  .cover-layout {
    grid-template-columns: 1.2fr 0.8fr;
    gap: 28px;
    align-items: center;
  }

  .bit-field {
    grid-template-columns: repeat(16, minmax(0, 1fr));
  }

  .chip-visual {
    width: min(170px, 25vw) !important;
    height: min(170px, 44vh) !important;
  }

  .chip-body {
    width: min(120px, 18vw) !important;
    height: min(120px, 31vh) !important;
  }
}

/* Three type roles and two accents are shared by every slide. */
.reveal .slides section.project-slide * {
  font-family: "Computer Modern Serif", "Times New Roman", serif !important;
  font-size: var(--type-body) !important;
  letter-spacing: 0 !important;
  text-transform: none !important;
}

.reveal .slides section.project-slide h1,
.reveal .slides section.project-slide h2,
.reveal .slides section.project-slide .big-result {
  font-size: var(--type-display) !important;
}

.reveal .slides section.project-slide h3,
.reveal .slides section.project-slide .metric > strong,
.reveal .slides section.project-slide .chip-body strong,
.reveal .slides section.project-slide .flow-box strong,
.reveal .slides section.project-slide .arch-node strong,
.reveal .slides section.project-slide .memory-front-end > strong,
.reveal .slides section.project-slide .memory-path strong,
.reveal .slides section.project-slide .timeline-step strong {
  font-size: var(--type-title) !important;
}

.reveal .slides section.project-slide code,
.reveal .slides section.project-slide .mono {
  font-family: "SFMono-Regular", Consolas, monospace !important;
}

.cover-meta {
  font-family: "Computer Modern Serif", "Times New Roman", serif;
}

@media (max-width: 900px) and (min-height: 651px) {
  :root {
    --type-display: 2.5rem;
    --type-title: 1.25rem;
    --type-body: 0.95rem;
  }
}

@media (min-width: 1600px) and (min-height: 651px) {
  :root {
    --type-display: 3.5rem;
    --type-title: 1.75rem;
    --type-body: 1.3rem;
  }

  .slide-shell {
    padding-right: 64px;
    padding-left: 64px;
  }

  .cover-slide .slide-shell {
    padding-right: 78px;
    padding-left: 78px;
  }

  .deck-arrows button {
    width: 58px;
    height: 58px;
  }
}

@media (max-height: 650px) {
  :root {
    --type-display: 1.8rem;
    --type-title: 1.05rem;
    --type-body: 0.8rem;
  }
}

@media print {
  .reveal .slides section .fragment {
    opacity: 1 !important;
    visibility: visible !important;
  }
}
/* Method overview: one neutral path, with benchmark detail nested under stage one. */
.method-overview-slide .slide-header {
  padding-bottom: clamp(28px, 4vh, 54px);
}

.method-overview-slide .slide-header h2 {
  max-width: 1280px;
}

.method-path {
  position: relative;
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  column-gap: clamp(34px, 5vw, 88px);
  width: 100%;
  padding-top: 26px;
}

.method-path::before {
  content: "";
  position: absolute;
  top: 8px;
  right: 0;
  left: 0;
  height: 2px;
  background: var(--line-dark);
}

.method-stage {
  position: relative;
  min-width: 0;
}

.method-marker {
  position: absolute;
  top: -26px;
  left: 0;
  display: grid;
  place-items: center;
  width: 36px;
  height: 36px;
  border: 2px solid var(--line-dark);
  border-radius: 50%;
  color: var(--ink);
  background: var(--paper);
  font-variant-numeric: tabular-nums;
}

.reveal .slides section.project-slide .method-marker span {
  font-weight: 700;
  line-height: 1;
}

.method-stage h3 {
  margin-top: 26px;
  max-width: 360px;
  line-height: 1.08 !important;
}

.method-purpose {
  max-width: 390px;
  margin-top: 12px !important;
  color: var(--muted) !important;
  line-height: 1.34 !important;
}

.method-subentry-list {
  display: grid;
  gap: 0;
  max-width: 390px;
  margin-top: 22px !important;
  padding: 0 !important;
  list-style: none;
  border-top: 1px solid var(--line);
}

.method-subentry-list li {
  display: grid;
  grid-template-columns: 112px minmax(0, 1fr);
  gap: 12px;
  align-items: baseline;
  padding: 9px 0;
  border-bottom: 1px solid var(--line);
}

.method-subentry-list strong {
  color: var(--ink);
  white-space: nowrap;
}

.method-subentry-list span {
  color: var(--muted);
  line-height: 1.25;
}

@media (max-width: 900px) and (min-height: 651px) {
  .method-overview-slide .slide-header {
    padding-bottom: 16px;
  }

  .method-path {
    grid-template-columns: minmax(0, 1fr);
    row-gap: 18px;
    padding-top: 0;
    padding-left: 35px;
  }

  .method-path::before {
    top: 0;
    right: auto;
    bottom: 0;
    left: 11px;
    width: 2px;
    height: auto;
  }

  .method-stage {
    min-height: 0;
  }

  .method-marker {
    top: 0;
    left: -35px;
    width: 24px;
    height: 24px;
  }

  .method-stage h3 {
    margin-top: 0;
  }

  .method-purpose {
    max-width: none;
    margin-top: 5px !important;
  }

  .method-subentry-list {
    grid-template-columns: repeat(3, minmax(0, 1fr));
    max-width: none;
    margin-top: 9px !important;
    border-top: 1px solid var(--line);
  }

  .method-subentry-list li {
    grid-template-columns: minmax(0, 1fr);
    gap: 2px;
    padding: 7px 9px 5px 0;
    border-bottom: 0;
  }

}

/* Bonsai model identity: the compressed block and the Transformer around it. */
.bonsai-model-slide .slide-header {
  padding-bottom: clamp(20px, 3vh, 36px);
}

.bonsai-model-slide .slide-header h2 {
  max-width: 1320px;
}

.bonsai-model-layout {
  display: grid;
  grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
  gap: clamp(42px, 6vw, 92px);
  align-items: stretch;
}

.bonsai-format-story {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.7fr);
  grid-template-areas:
    "label label label"
    "sign plus scale"
    "result result result"
    "meaning meaning meaning";
  column-gap: 16px;
  align-items: end;
  padding: 2px 0 0;
  border-top: 2px solid var(--ink);
}

.bonsai-format-label {
  grid-area: label;
  padding-top: 10px;
  color: var(--muted) !important;
}

.bonsai-format-line {
  grid-area: sign;
  display: grid;
  align-content: end;
  min-width: 0;
  padding: 15px 0 12px;
}

.bonsai-format-scale {
  grid-area: scale;
}

.bonsai-format-line h3 {
  color: var(--rust);
  line-height: 0.86;
  font-variant-numeric: tabular-nums;
}

.bonsai-format-line span {
  display: block;
  margin-top: 8px;
  color: var(--ink);
  line-height: 1.12;
}

.bonsai-format-plus {
  grid-area: plus;
  align-self: center;
  padding-bottom: 10px;
  color: var(--line-dark);
  font-weight: 700;
}

.bonsai-format-result {
  grid-area: result;
  display: flex;
  align-items: baseline;
  gap: 8px;
  padding: 10px 0 9px;
  border-top: 1px solid var(--line);
  border-bottom: 1px solid var(--line);
}

.bonsai-format-meaning {
  grid-area: meaning;
  max-width: 500px;
  padding-top: 10px;
  color: var(--muted) !important;
  line-height: 1.3 !important;
}

.bonsai-transformer-story {
  border-top: 2px solid var(--ink);
}

.bonsai-transformer-intro {
  max-width: 620px;
  padding: 10px 0 12px;
  color: var(--muted) !important;
  line-height: 1.3 !important;
}

.bonsai-spec-list {
  margin: 0;
}

.bonsai-spec-list > div {
  display: grid;
  grid-template-columns: 110px minmax(0, 1fr);
  gap: 18px;
  align-items: baseline;
  padding: 10px 0;
  border-top: 1px solid var(--line);
}

.bonsai-spec-list dt,
.bonsai-spec-list dd {
  margin: 0;
}

.bonsai-spec-list dt {
  color: var(--muted);
}

.bonsai-spec-list dd {
  color: var(--ink);
  font-weight: 700;
}

.bonsai-scope-line {
  display: grid;
  grid-template-columns: auto minmax(0, 1fr);
  gap: 22px;
  align-items: baseline;
  margin-top: clamp(20px, 3vh, 34px);
  padding-top: 12px;
  border-top: 2px solid var(--ink);
}

.bonsai-scope-line h3 {
  white-space: nowrap;
}

.bonsai-scope-line span {
  color: var(--muted);
  line-height: 1.3;
}

@media (max-width: 900px) and (min-height: 651px) {
  .bonsai-model-slide .slide-header {
    padding-bottom: 14px;
  }

  .bonsai-model-layout {
    grid-template-columns: minmax(0, 1fr);
    gap: 18px;
  }

  .bonsai-format-story {
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 0.72fr);
  }

  .bonsai-format-meaning {
    max-width: none;
  }

  .bonsai-transformer-intro {
    max-width: none;
    padding-bottom: 7px;
  }

  .bonsai-spec-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: 22px;
  }

  .bonsai-spec-list > div {
    grid-template-columns: 82px minmax(0, 1fr);
    gap: 8px;
    padding: 7px 0;
  }

  .bonsai-scope-line {
    grid-template-columns: minmax(0, 1fr);
    gap: 4px;
    margin-top: 16px;
    padding-top: 9px;
  }
}

@media (max-width: 520px) and (min-height: 651px) {
  .bonsai-model-slide .subtitle {
    display: none;
  }

  .bonsai-model-layout {
    gap: 11px;
  }

  .bonsai-format-story {
    column-gap: 10px;
  }

  .bonsai-format-label {
    padding-top: 6px;
  }

  .bonsai-format-line {
    padding: 8px 0 7px;
  }

  .bonsai-format-line span,
  .bonsai-format-meaning,
  .bonsai-transformer-intro,
  .bonsai-scope-line span {
    line-height: 1.18 !important;
  }

  .bonsai-format-result {
    padding: 6px 0;
  }

  .bonsai-format-meaning {
    padding-top: 6px;
  }

  .bonsai-transformer-intro {
    padding: 6px 0 4px;
  }

  .bonsai-spec-list {
    grid-template-columns: minmax(0, 1fr);
  }

  .bonsai-spec-list > div {
    grid-template-columns: 74px minmax(0, 1fr);
    padding: 4px 0;
  }

  .bonsai-scope-line {
    margin-top: 9px;
    padding-top: 6px;
  }

}

@media (max-height: 650px) and (min-aspect-ratio: 4 / 3) {
  .bonsai-model-slide .slide-header {
    padding-bottom: 12px;
  }

  .bonsai-model-layout {
    gap: 34px;
  }

  .bonsai-format-label,
  .bonsai-transformer-intro {
    padding-top: 6px;
    padding-bottom: 5px;
  }

  .bonsai-format-line {
    padding: 7px 0 5px;
  }

  .bonsai-format-line span {
    margin-top: 4px;
  }

  .bonsai-format-result {
    padding: 5px 0;
  }

  .bonsai-format-meaning {
    padding-top: 5px;
  }

  .bonsai-spec-list > div {
    padding: 5px 0;
  }

  .bonsai-scope-line {
    margin-top: 10px;
    padding-top: 6px;
  }
}

@media (max-width: 520px) and (min-height: 651px) {
  .method-overview-slide .subtitle {
    display: none;
  }

  .method-path {
    row-gap: 12px;
  }

  .method-subentry-list {
    grid-template-columns: minmax(0, 1fr);
  }

  .method-subentry-list li {
    grid-template-columns: 108px minmax(0, 1fr);
    gap: 7px;
    padding: 4px 0;
    border-bottom: 1px solid var(--line);
  }
}

@media (max-height: 650px) and (min-aspect-ratio: 4 / 3) {
  .method-overview-slide .slide-header {
    padding-bottom: 20px;
  }

  .method-path {
    column-gap: 34px;
    padding-top: 18px;
  }

  .method-path::before {
    top: 5px;
  }

  .method-marker {
    top: -18px;
    width: 27px;
    height: 27px;
  }

  .method-stage h3 {
    margin-top: 18px;
  }

  .method-purpose {
    margin-top: 6px !important;
  }

  .method-subentry-list {
    margin-top: 9px !important;
  }

  .method-subentry-list li {
    padding: 5px 0;
  }

}
