+// Small aggregate profiler for BLAS-backed ops. It intentionally records by
+// ggml op and src0 type because the benchmark only needs bottleneck classes.
+struct ggml_blas_op_profile_entry {
+    uint64_t calls = 0;
+    uint64_t time_us = 0;
+    uint64_t dst_elems = 0;
+    uint64_t q1_groups = 0;
+    uint64_t weight_apps = 0;
+};
+
+static ggml_blas_op_profile_entry ggml_blas_op_profile[GGML_OP_COUNT][GGML_TYPE_COUNT + 1];
+static bool ggml_blas_op_profile_enabled = false;
+static bool ggml_blas_op_profile_initialized = false;
+
+// Count logical output elements in a tensor. These are later combined with the
+// input width, to estimate how many fixed-weight applications each matmul did.
+static uint64_t ggml_blas_nelements_u64(const ggml_tensor * tensor) {
+    if (tensor == nullptr) {
+        return 0;
+    }
+
+    uint64_t result = 1;
+    for (int i = 0; i < GGML_MAX_DIMS; i++) {
+        result *= (uint64_t) tensor->ne[i];
+    }
+    return result;
+}
+
+// CSV-like table at process exit. The Python benchmark parser
+// looks for the GGML_BLAS_OP_PROFILE marker and then reads the following rows.
+static void ggml_blas_op_profile_print() {
+    uint64_t total_us = 0;
+    for (int op = 0; op < GGML_OP_COUNT; op++) {
+        for (int type = 0; type <= GGML_TYPE_COUNT; type++) {
+            total_us += ggml_blas_op_profile[op][type].time_us;
+        }
+    }
+
+    if (total_us == 0) {
+        return;
+    }
+
+    fprintf(stderr, "\nGGML_BLAS_OP_PROFILE,csv_v1,total_us,%" PRIu64 "\n", total_us);
+    fprintf(stderr, "op,src0_type,calls,time_us,pct,dst_elems,q1_groups,weight_apps\n");
+
+    for (int op = 0; op < GGML_OP_COUNT; op++) {
+        for (int type = 0; type <= GGML_TYPE_COUNT; type++) {
+            const ggml_blas_op_profile_entry & entry = ggml_blas_op_profile[op][type];
+            if (entry.calls == 0) {
+                continue;
+            }
+
+            const char * type_name = (type == GGML_TYPE_COUNT) ? "none" : ggml_type_name((ggml_type) type);
+            const double pct = 100.0 * (double) entry.time_us / (double) total_us;
+
+            fprintf(stderr, "%s,%s,%" PRIu64 ",%" PRIu64 ",%.4f,%" PRIu64 ",%" PRIu64 ",%" PRIu64 "\n",
+                    ggml_op_name((ggml_op) op), type_name, entry.calls, entry.time_us, pct,
+                    entry.dst_elems, entry.q1_groups, entry.weight_apps);
+        }
+    }
+}
+
+// Enable BLAS profiling only when requested. GGML_CPU_OP_PROFILE also enables
+// this block so taht one environment variable captures both CPU and BLAS backends.
+static void ggml_blas_op_profile_init() {
+    if (ggml_blas_op_profile_initialized) {
+        return;
+    }
+
+    ggml_blas_op_profile_initialized = true;
+    ggml_blas_op_profile_enabled = getenv("GGML_BLAS_OP_PROFILE") != nullptr || getenv("GGML_CPU_OP_PROFILE") != nullptr;
+
+    if (ggml_blas_op_profile_enabled) {
+        atexit(ggml_blas_op_profile_print);
+    }
+}
+
+// Accumulate one finished BLAS op. For Q1_0 matmuls, q1_groups estimates the
+// number of group-128 dequant/dot-product chunks (accelerator work unit we care).
+static void ggml_blas_op_profile_record(const ggml_tensor * tensor, int64_t time_us) {
+    if (!ggml_blas_op_profile_enabled || tensor == nullptr || tensor->op >= GGML_OP_COUNT || time_us < 0) {
+        return;
+    }
+
+    const ggml_tensor * src0 = tensor->src[0];
+    const int type = (src0 != nullptr && src0->type < GGML_TYPE_COUNT) ? src0->type : GGML_TYPE_COUNT;
+
+    ggml_blas_op_profile_entry & entry = ggml_blas_op_profile[tensor->op][type];
+    const uint64_t dst_elems = ggml_blas_nelements_u64(tensor);
+
+    entry.calls++;
+    entry.time_us += (uint64_t) time_us;
+    entry.dst_elems += dst_elems;
+
+    if ((tensor->op == GGML_OP_MUL_MAT || tensor->op == GGML_OP_MUL_MAT_ID) && src0 != nullptr) {
+        const uint64_t src0_cols = (uint64_t) src0->ne[0];
+        entry.weight_apps += dst_elems * src0_cols;
+
+        if (src0->type == GGML_TYPE_Q1_0) {
+            entry.q1_groups += dst_elems * ((src0_cols + 127) / 128);
+        }
+    }
+}
