+// Aggregate CPU-side op timings by ggml op and src0 tensor type. This is kept
+// intentionally coarse so the logs stay small.
+struct ggml_cpu_op_profile_entry {
+    uint64_t calls;
+    uint64_t time_us;
+    uint64_t dst_elems;
+    uint64_t q1_groups;
+    uint64_t weight_apps;
+};
+
+static struct ggml_cpu_op_profile_entry ggml_cpu_op_profile[GGML_OP_COUNT][GGML_TYPE_COUNT + 1];
+static bool ggml_cpu_op_profile_enabled = false;
+static bool ggml_cpu_op_profile_initialized = false;
+static bool ggml_cpu_op_profile_active = false;
+static uint64_t ggml_cpu_op_profile_skip_graphs = 0;
+static uint64_t ggml_cpu_op_profile_graphs = 0;
+
+// Count logical output elements in a tensor. For matmul-like ops this combines
+// with src0 width to estimate fixed-weight applications.
+static uint64_t ggml_cpu_nelements_u64(const struct ggml_tensor * tensor) {
+    if (tensor == NULL) {
+        return 0;
+    }
+
+    uint64_t result = 1;
+    for (int i = 0; i < GGML_MAX_DIMS; i++) {
+        result *= (uint64_t) tensor->ne[i];
+    }
+    return result;
+}
+
+// Print a stable CSV-like table at process exit. The benchmark script parses
+// this marker to build prefill/decode bottleneck summaries.
+static void ggml_cpu_op_profile_print(void) {
+    uint64_t total_us = 0;
+    for (int op = 0; op < GGML_OP_COUNT; op++) {
+        for (int type = 0; type <= GGML_TYPE_COUNT; type++) {
+            total_us += ggml_cpu_op_profile[op][type].time_us;
+        }
+    }
+
+    if (total_us == 0) {
+        return;
+    }
+
+    fprintf(stderr, "\nGGML_CPU_OP_PROFILE,csv_v1,total_us,%" PRIu64 "\n", total_us);
+    fprintf(stderr, "op,src0_type,calls,time_us,pct,dst_elems,q1_groups,weight_apps\n");
+
+    for (int op = 0; op < GGML_OP_COUNT; op++) {
+        for (int type = 0; type <= GGML_TYPE_COUNT; type++) {
+            const struct ggml_cpu_op_profile_entry * entry = &ggml_cpu_op_profile[op][type];
+            if (entry->calls == 0) {
+                continue;
+            }
+
+            const char * type_name = (type == GGML_TYPE_COUNT) ? "none" : ggml_type_name((enum ggml_type) type);
+            const double pct = 100.0 * (double) entry->time_us / (double) total_us;
+
+            fprintf(stderr, "%s,%s,%" PRIu64 ",%" PRIu64 ",%.4f,%" PRIu64 ",%" PRIu64 ",%" PRIu64 "\n",
+                    ggml_op_name((enum ggml_op) op), type_name, entry->calls, entry->time_us, pct,
+                    entry->dst_elems, entry->q1_groups, entry->weight_apps);
+        }
+    }
+}
+
+// GGML_CPU_OP_PROFILE opt-in keeps normal llama.cpp runs unchanged. The optional
+// skip count ignores warm-up graphs that are not representative of work.
+static void ggml_cpu_op_profile_init(void) {
+    if (ggml_cpu_op_profile_initialized) {
+        return;
+    }
+
+    ggml_cpu_op_profile_initialized = true;
+    ggml_cpu_op_profile_enabled = getenv("GGML_CPU_OP_PROFILE") != NULL;
+
+    if (ggml_cpu_op_profile_enabled) {
+        const char * skip_graphs = getenv("GGML_CPU_OP_PROFILE_SKIP_GRAPHS");
+        if (skip_graphs != NULL) {
+            ggml_cpu_op_profile_skip_graphs = (uint64_t) strtoull(skip_graphs, NULL, 10);
+        }
+        atexit(ggml_cpu_op_profile_print);
+    }
+}
+
+// Accumulate one finished CPU op
+static void ggml_cpu_op_profile_record(const struct ggml_tensor * tensor, int64_t time_us) {
+    if (!ggml_cpu_op_profile_enabled || !ggml_cpu_op_profile_active || tensor == NULL || tensor->op >= GGML_OP_COUNT || time_us < 0) {
+        return;
+    }
+
+    const struct ggml_tensor * src0 = tensor->src[0];
+    const struct ggml_tensor * src1 = tensor->src[1];
+    const int type = (src0 != NULL && src0->type < GGML_TYPE_COUNT) ? src0->type : GGML_TYPE_COUNT;
+
+    struct ggml_cpu_op_profile_entry * entry = &ggml_cpu_op_profile[tensor->op][type];
+
+    entry->calls++;
+    entry->time_us += (uint64_t) time_us;
+    entry->dst_elems += ggml_cpu_nelements_u64(tensor);
+
+    if ((tensor->op == GGML_OP_MUL_MAT || tensor->op == GGML_OP_MUL_MAT_ID) && src0 != NULL && src1 != NULL) {
+        const uint64_t src0_cols = (uint64_t) src0->ne[0];
+        const uint64_t dst_elems = ggml_cpu_nelements_u64(tensor);
+        entry->weight_apps += dst_elems * src0_cols;
+
+        if (src0->type == GGML_TYPE_Q1_0) {
+            entry->q1_groups += dst_elems * ((src0_cols + 127) / 128);
+        }
+    }
+}
